graph LR
    subgraph "横向公共层"
        account[account]
        context[context]
    end
    
    subgraph "纵向处理链"
        front[front]
        worker[worker]
        session[session]
        dispatch[dispatch<br/>header-only]
        pipeline[pipeline]
        resolve[resolve]
    end
    
    subgraph "底层依赖"
        transport[transport]
        protocol[protocol]
        memory[memory]
    end
    
    front --> worker
    worker --> session
    worker --> resolve
    session --> dispatch
    session --> pipeline
    dispatch --> pipeline
    pipeline --> resolve
    resolve --> transport
    pipeline --> transport
    
    account --> memory
    context --> account
    context --> resolve
