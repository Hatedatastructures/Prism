sequenceDiagram
    participant Main
    participant Listener
    participant Balancer
    participant Worker
    participant Launch
    participant Session
    participant Dispatch
    participant Handler
    participant Pipeline
    participant Router
    participant Transport

    Main->>Listener: listen()
    Listener->>Listener: accept_loop()
    Listener->>Balancer: select(affinity)
    Balancer-->>Listener: worker_index
    Listener->>Worker: dispatch(socket)
    Worker->>Launch: dispatch()
    Launch->>Session: make_session()
    Session->>Session: start()
    Session->>Dispatch: registry::create(type)
    Dispatch-->>Session: handler
    Session->>Handler: process(ctx, data)
    Handler->>Pipeline: http/socks5/tls()
    Pipeline->>Router: dial()
    Router->>Transport: connect upstream
    Pipeline->>Pipeline: original_tunnel()
